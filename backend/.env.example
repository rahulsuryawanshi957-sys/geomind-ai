# Free, no credit card required: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
EMBEDDING_MODEL=gemini-embedding-001
CHAT_MODEL=gemini-3.5-flash

# --- Optional: for PERMANENT storage (skip these and everything still works,
# but uploaded documents + chat history get wiped on every restart/redeploy
# on Render's free tier) ---

# Free tier at https://trychroma.com -- makes indexed documents persist forever
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=raahigeo

# Free Postgres at https://supabase.com or https://neon.tech -- makes chat
# history / document list persist forever. Leave blank to use local SQLite.
DATABASE_URL=

CORS_ORIGINS=https://geomind-ai-1.onrender.com,http://localhost:5173,http://localhost:3000
